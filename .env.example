# Firebase Configuration (Get from firebase.json / Firebase Console)
FIREBASE_PROJECT_ID=food-ai-app
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here

# Cloudinary Configuration (Get from Cloudinary Dashboard)
# 1. Cloud Name: https://cloudinary.com/console/c-xxx/settings/general
# 2. API Key: Same dashboard
# 3. Upload Preset: Create at https://cloudinary.com/console/c-xxx/settings/upload
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# AI API Configuration
AI_API_BASE_URL=http://10.0.2.2:8000
AI_API_TIMEOUT_SECONDS=30

# App Configuration
APP_DEBUG=true
APP_VERSION=1.0.0

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in actual values in .env
# 3. Add .env to .gitignore (already done)
# 4. DO NOT commit .env - it contains secrets!
